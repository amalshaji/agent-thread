{
  "name": "agent-thread",
  "version": "0.1.0",
  "type": "module",
  "description": "Share Claude Code sessions as public links",
  "bin": {
    "agent-thread": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "cli": "bun run ./src/cli/index.ts",
    "build": "bun run scripts/build-cli.ts",
    "dev": "bunx wrangler dev",
    "deploy": "bunx wrangler deploy",
    "test": "bun test",
    "check": "bun ./node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@pierre/diffs": "^1.1.5",
    "hono": "^4.8.3",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/markdown-it": "^14.1.2",
    "puppeteer": "^24.40.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.10.0"
  }
}
