{
  "name": "agent-thread",
  "version": "0.1.7",
  "type": "module",
  "description": "Share Claude Code and Codex sessions as public links",
  "license": "MIT",
  "author": "Amal Shaji",
  "homepage": "https://github.com/amalshaji/agent-thread#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amalshaji/agent-thread.git"
  },
  "bugs": {
    "url": "https://github.com/amalshaji/agent-thread/issues"
  },
  "keywords": [
    "agent",
    "claude-code",
    "codex",
    "transcript",
    "cloudflare"
  ],
  "bin": {
    "agent-thread": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "cli": "bun run ./src/cli/index.ts",
    "build": "bun --bun ./node_modules/next/dist/bin/next build && bun --bun ./node_modules/@opennextjs/cloudflare/dist/cli/index.js build && bun run scripts/build-cli.ts",
    "build:cli": "bun run scripts/build-cli.ts",
    "dev": "bun --bun ./node_modules/next/dist/bin/next dev",
    "preview": "bun --bun ./node_modules/@opennextjs/cloudflare/dist/cli/index.js build && bun --bun ./node_modules/@opennextjs/cloudflare/dist/cli/index.js preview",
    "deploy": "bun --bun ./node_modules/@opennextjs/cloudflare/dist/cli/index.js build && bun --bun ./node_modules/@opennextjs/cloudflare/dist/cli/index.js deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "test": "bun test",
    "check": "bun ./node_modules/typescript/lib/tsc.js --noEmit"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@clack/prompts": "^0.11.0",
    "@next/swc-wasm-nodejs": "^15.5.15",
    "@opennextjs/cloudflare": "^1.19.4",
    "@pierre/diffs": "^1.1.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bun": "^1.3.1",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "markdown-it": "^14.1.1",
    "next": "^15.5.15",
    "puppeteer": "^24.40.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.85.0"
  }
}
